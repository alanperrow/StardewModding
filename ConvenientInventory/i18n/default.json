  "ModConfigMenu.QuickStackNonStackableTypesToOverflow.Name": "Overflow non-stackables:",
  "ModConfigMenu.QuickStackNonStackableTypesToOverflow.Desc": "(Requires \"Overflow items?\" to be enabled.)\nChoose which non-stackable item types can be quick stacked as\noverflow items if a chest contains that same item.\n\nChoose \"None\" if non-stackable items should NOT be quick stacked.",
  "ModConfigMenu.QuickStackNonStackableTypesToOverflow.Desc-None": "None",
  "ModConfigMenu.QuickStackNonStackableTypesToOverflow.Desc-All": "All",
